---
import site from '../../site.config.json';
interface Props {
  title: string;
  description?: string;
  /** force noindex even post-stealth (e.g. 404, guides while thin) */
  noindex?: boolean;
  ogType?: string;
}
const { title, description = '', noindex = false, ogType = 'website' } = Astro.props;
const robots = site.stealth || noindex ? 'noindex, nofollow' : 'index, follow';
const canonical = new URL(Astro.url.pathname, site.SITE).href;
const ga4 = (site.ga4 && site.ga4.measurementId) || '';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <slot name="head" />
  {ga4 && (
    <Fragment>
      {/* Google Consent Mode v2 — analytics_storage denied until the visitor accepts.
          GA4 still receives cookieless pings while denied, so traffic is measured
          from day one (Raptive requires GA history and it cannot be backfilled). */}
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        var __c = null;
        try { __c = localStorage.getItem('consent-analytics'); } catch (e) {}
        gtag('consent', 'default', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: __c === 'granted' ? 'granted' : 'denied'
        });
      </script>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4}`}></script>
      <script is:inline define:vars={{ ga4 }}>
        gtag('js', new Date());
        gtag('config', ga4);
      </script>
    </Fragment>
  )}
</head>
<body>
  <slot />

  {ga4 && (
    <div id="cookie-banner" class="cookie-banner" hidden>
      <p>
        We use cookies for analytics to understand what's useful here. Ads and
        affiliate links, where present, are always disclosed. See our
        <a href="/privacy/">privacy policy</a>.
      </p>
      <div class="cookie-actions">
        <button type="button" data-consent="denied" class="cookie-btn ghost">Decline</button>
        <button type="button" data-consent="granted" class="cookie-btn">Accept</button>
      </div>
    </div>
  )}

  <script is:inline>
    // ---- Cookie consent (interim). Mediavine's CMP replaces this at Journey approval. ----
    const banner = document.getElementById('cookie-banner');
    if (banner) {
      let stored = null;
      try { stored = localStorage.getItem('consent-analytics'); } catch (e) {}
      if (!stored) banner.hidden = false;
      banner.querySelectorAll('[data-consent]').forEach((b) => {
        b.addEventListener('click', () => {
          const v = b.getAttribute('data-consent');
          try { localStorage.setItem('consent-analytics', v); } catch (e) {}
          if (window.gtag) window.gtag('consent', 'update', { analytics_storage: v });
          banner.hidden = true;
        });
      });
    }
  </script>

  <script>
    // Global subscribe handler: any <form data-subscribe> posts the email to
    // /api/subscribe, which stores it in D1 AND subscribes it to this site's
    // MailerLite group (which triggers magnet delivery + the nurture sequence).
    // The file is also handed over instantly so the visitor never waits on email.
    import site from '../../site.config.json';
    const magnet = site.magnet || {};
    document.querySelectorAll('form[data-subscribe]').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const input = form.querySelector('input[type="email"]');
        const btn = form.querySelector('button');
        const email = input && input.value ? input.value.trim() : '';
        if (!email) return;
        if (btn) { btn.disabled = true; btn.dataset.orig = btn.textContent; btn.textContent = '...'; }
        let ok = false;
        try {
          const r = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ email })
          });
          ok = r.ok;
        } catch (err) {}
        const msg = document.createElement('p');
        msg.className = 'subscribe-done';
        if (ok && magnet.file) {
          const a = document.createElement('a');
          a.href = magnet.file; a.download = ''; document.body.appendChild(a); a.click(); a.remove();
          msg.innerHTML = (magnet.doneMessage || 'You are in - your download is starting now.') +
            ' <a href="' + magnet.file + '" download>Download did not start?</a>';
        } else if (ok) {
          msg.textContent = 'You are in - check your inbox.';
        } else {
          msg.textContent = 'Something went wrong - please try again.';
          if (btn) { btn.disabled = false; btn.textContent = btn.dataset.orig; }
        }
        form.insertAdjacentElement('afterend', msg);
        if (ok) form.hidden = true;
      });
    });
  </script>


  <script is:inline>
    (function () {
      document.addEventListener('click', function (e) {
        var el = e.target.closest('a.ad-filled, aside.offer-box a');
        if (!el) return;
        if (typeof gtag !== 'function') return;
        var slot = el.closest('aside.offer-box') ? 'offer_box' : 'banner';
        gtag('event', 'offer_click', {
          site: window.location.hostname,
          slot: slot,
          target_url: el.href,
          page: window.location.pathname
        });
      }, true);
    })();
  </script>
  <style is:global>
    .cookie-banner[hidden] { display: none; }
    .cookie-banner {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
      display: flex; flex-wrap: wrap; gap: 12px 24px;
      align-items: center; justify-content: center;
      padding: 14px 20px; background: #16181B; color: #F4F2ED;
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; font-size: 14px;
      box-shadow: 0 -2px 18px rgba(0,0,0,.22);
    }
    .cookie-banner p { margin: 0; max-width: 70ch; }
    .cookie-banner a { color: inherit; text-decoration: underline; }
    .cookie-actions { display: flex; gap: 10px; }
    .cookie-btn {
      border: 0; border-radius: 6px; padding: 9px 18px; cursor: pointer;
      font: inherit; font-weight: 700; background: #F4F2ED; color: #16181B;
    }
    .cookie-btn.ghost { background: transparent; color: #F4F2ED; border: 1px solid rgba(244,242,237,.45); }
    .cookie-btn:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }
  </style>

  <style is:global>
:root{--navy:#042d49;--deep:#064e73;--blue:#087fac;--aqua:#37d3d0;--coral:#ff6b57;--yellow:#ffd45c;--ink:#07334c;--glass:rgba(255,255,255,.84)}
  *{box-sizing:border-box}html{scroll-behavior:smooth}
  body{margin:0;color:var(--ink);background:#f6fffe;font:16px/1.6 "Trebuchet MS","Avenir Next",Arial,sans-serif}
  a{color:inherit;text-decoration:none}button,input,select{font:inherit}
  .sr{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)}
  .nav{position:sticky;z-index:20;top:10px;width:min(1160px,calc(100% - 24px));margin:10px auto 0;padding:10px 12px 10px 18px;display:flex;align-items:center;justify-content:space-between;gap:18px;border:1px solid #ffffffb8;border-radius:18px;background:#f7fffee6;box-shadow:0 8px 30px #01375321;backdrop-filter:blur(18px)}
  .brand{display:flex;align-items:center;gap:9px;font-size:20px;font-weight:900;white-space:nowrap}.brand b{color:var(--blue)}
  .wave{width:34px;height:25px;border-radius:50%;background:linear-gradient(155deg,var(--yellow) 0 30%,transparent 31%),linear-gradient(var(--aqua),var(--blue));box-shadow:inset 0 -7px #ffffff59;transform:rotate(-7deg)}
  .nav nav{display:flex;gap:23px;font-size:14px;font-weight:800}
  .btn,form.email button{display:inline-flex;justify-content:center;align-items:center;border:0;border-radius:12px;padding:13px 20px;background:var(--coral);color:white;font-weight:900;cursor:pointer;box-shadow:0 7px #d94938,0 13px 25px #d9493840;transition:.2s}
  .btn:hover,form.email button:hover{transform:translateY(-2px)}.btn.sm{padding:8px 14px;font-size:12px;box-shadow:none}
  .ad{height:90px;width:min(970px,calc(100% - 32px));margin:27px auto;display:grid;place-items:center;border:1px dashed #aac8ce;border-radius:10px;background:#eff8f7;color:#688391;font:11px Arial;letter-spacing:1.8px;text-transform:uppercase}
  .water{position:relative;overflow:hidden;isolation:isolate;background:linear-gradient(135deg,#063f66,#078bb7 58%,#3bd7cf)}
  .water:before{content:"";position:absolute;z-index:-1;inset:-40%;opacity:.18;background:repeating-radial-gradient(ellipse at 30% 30%,transparent 0 26px,#fff 27px 29px,transparent 31px 62px);transform:rotate(-14deg);animation:caustics 16s linear infinite}
  .hero{min-height:700px;padding:100px max(24px,calc((100% - 1120px)/2));display:grid;grid-template-columns:1.3fr .7fr;gap:65px;align-items:center}
  .glass{background:var(--glass);border:1px solid #ffffffa8;border-radius:28px;box-shadow:0 24px 60px #0027442e;backdrop-filter:blur(18px)}
  .hero-card{padding:48px}
  .eyebrow{margin:0 0 10px;color:#087c91;font-size:12px;letter-spacing:2px;text-transform:uppercase;font-weight:900}.light{color:#b7ffec}
  .hero h1{max-width:820px;margin:0 0 24px;color:var(--navy);font-size:clamp(42px,6vw,76px);line-height:1.01;letter-spacing:-3px}
  .lede{font-size:19px}
  form.email{display:flex;gap:10px;margin-top:26px}form.email input{min-width:0;flex:1;padding:14px;border:2px solid transparent;border-radius:12px}
  form.email input:focus,input:focus,select:focus{outline:3px solid var(--yellow)}
  .micro{font-size:12px;color:#52717d}
  .pool-disc{width:270px;aspect-ratio:1;display:grid;place-content:center;text-align:center;color:white;border:1px solid #ffffff5c;border-radius:50%;background:#03395b38;box-shadow:inset 0 0 0 28px #ffffff14;animation:float 5s ease-in-out infinite}
  .pool-disc b{font-size:72px;line-height:1}.pool-disc small{letter-spacing:2px;text-transform:uppercase}
  .proof{padding:25px max(24px,calc((100% - 1120px)/2));display:flex;justify-content:space-between;align-items:center;gap:25px;background:var(--navy);color:white}
  .proof strong{color:var(--yellow);font-size:27px}.proof small{display:block}
  .badges{display:flex;flex-wrap:wrap;gap:8px}.badges span{padding:7px 10px;border:1px solid #ffffff40;border-radius:99px;font-size:12px}
  .section{padding:105px max(24px,calc((100% - 1120px)/2))}
  .head{max-width:680px;margin-bottom:42px}
  .head h2,.schedule h2,.offer h2,.final h2{margin:0 0 15px;color:var(--navy);font-size:clamp(34px,4.7vw,58px);line-height:1.04;letter-spacing:-2px}
  .problem{background:linear-gradient(#fff,#e8f8f6)}
  .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
  .card{padding:30px;transition:.25s}.card:hover{transform:translateY(-7px)}.card h3{margin:38px 0 10px;font-size:24px}
  .num{color:var(--blue);font-size:12px;font-weight:900}
  .schedule{position:relative;overflow:hidden;display:grid;grid-template-columns:.85fr 1.15fr;gap:70px;align-items:center;background:linear-gradient(120deg,#064e73,#06a6b8);color:white}
  .schedule h2{color:white}
  .check{padding:34px;color:var(--ink)}.check ul{padding:0;list-style:none}
  .check li{padding:9px 0;border-bottom:1px solid #c7e6e4}.check li:before{content:"✓";margin-right:10px;color:#087c6c;font-weight:900}
  .compact{display:grid}
  .offer{display:grid;grid-template-columns:1.35fr .65fr;gap:70px;align-items:center;background:white}
  .chips{display:flex;gap:8px;flex-wrap:wrap}.chips span{padding:7px 12px;border-radius:99px;background:#e6f7f5;font-size:13px;font-weight:800}
  .price{text-align:center;padding:35px}.price>strong{display:block;font-size:78px;line-height:1.2}.price .btn{display:flex}.price small{display:block;margin-top:17px}
  .calc-wrap{padding:105px max(18px,calc((100% - 1120px)/2))}.calc-wrap .head,.calc-wrap h2{color:white}
  .byline{display:grid;grid-template-columns:150px 1fr;gap:34px;align-items:center;background:white}
  .avatar{width:145px;height:145px;display:grid;place-items:center;border-radius:50%;background:linear-gradient(135deg,#cdf6ef,#70d9d4);font-size:10px;box-shadow:0 12px 40px #b2d7d5}
  .faq{background:#ecf9f7}.faq-list{max-width:850px}
  .faq details{margin:10px 0;padding:0 20px;border:1px solid #c9e0df;border-radius:14px;background:white}
  .faq summary{padding:19px 0;display:flex;justify-content:space-between;cursor:pointer;list-style:none;font-weight:900}
  .faq details p{margin:0 0 20px;color:#496773}.faq summary span{font-size:24px;color:var(--blue)}.faq details[open] summary span{transform:rotate(45deg)}
  .final{padding:105px 24px;text-align:center;color:white}.final h2{color:white;font-size:clamp(44px,7vw,84px)}
  .actions{display:flex;justify-content:center;align-items:center;gap:25px}.text-link{border-bottom:2px solid var(--yellow);font-weight:900}
  footer{padding:52px max(24px,calc((100% - 1120px)/2));display:grid;grid-template-columns:1fr 1fr;gap:25px;background:#032b43;color:#d9edf0}
  footer nav{display:flex;gap:23px;justify-content:flex-end;flex-wrap:wrap;font-size:14px;font-weight:800}
  footer p{grid-column:1/-1;max-width:760px;font-size:13px;color:#a9c5cc}
  @keyframes caustics{to{transform:translate(10%,8%) rotate(-14deg)}}
  @keyframes float{50%{transform:translateY(-14px)}}

  /* ---- ClearCove skin for the shared Tool engine (glass, matches design) ---- */
  .calc{background:var(--glass);border:1px solid #ffffffa8;border-radius:28px;box-shadow:0 24px 60px #0027442e;backdrop-filter:blur(18px)}
  .calc-inputs,.calc-results{padding:38px}
  .calc-field input,.calc-field select{border:1px solid #bcd4d6}
  .calc-results{background:#eef8d5;border-radius:0}
  .calc-results.tone-warn{background:#fff1bd}.calc-results.tone-bad{background:#d8e2d4}
  .calc-dot{box-shadow:0 0 0 7px #29ad6a26}
  .tone-warn .calc-dot{background:#df9d0a}.tone-bad .calc-dot{background:#67785f}

  @media(max-width:850px){.nav nav{display:none}.hero,.schedule,.offer{grid-template-columns:1fr}.hero{min-height:auto}.pool-disc{display:none}.proof{align-items:flex-start}.cards{grid-template-columns:1fr}.byline{grid-template-columns:110px 1fr}.avatar{width:100px;height:100px}}
  @media(max-width:580px){.hero{padding:65px 14px 80px}.hero-card{padding:25px 20px}.hero h1{font-size:43px}form.email{display:grid}.section{padding-top:75px;padding-bottom:75px}.calc-inputs,.calc-results{padding:25px 20px}.proof{flex-direction:column}.byline{grid-template-columns:1fr}.actions{flex-direction:column}footer{grid-template-columns:1fr}footer nav{justify-content:flex-start;display:grid;grid-template-columns:1fr 1fr}}
  @media(prefers-reduced-motion:reduce){*,*:before,*:after{animation:none!important;transition:none!important;scroll-behavior:auto!important}}
  </style>
</body>
</html>
