---
import site from '../../site.config.json';
import Base from '../layouts/Base.astro';
const t = site.theme;
---
<Base title={`${site.BRAND} — Coming Soon`} description={site.comingSoon.promise} noindex={true}>
  <main class="cs">
    <div class="cs-card">
      <p class="cs-brand">{site.BRAND}</p>
      <h1>{site.comingSoon.promise}</h1>
      <form class="cs-form" action={site.mailerlite.formAction} method="post">
        <label class="sr" for="cs-email">Email address</label>
        <input id="cs-email" name="fields[email]" type="email" required placeholder="you@example.com" />
        <button type="submit">{site.comingSoon.captureLabel}</button>
      </form>
      <p class="cs-micro">Free. No spam. Unsubscribe anytime.</p>
    </div>
  </main>
</Base>

<style define:vars={{ bg: t.bg, ink: t.ink, accent: t.accent, headingFont: t.headingFont, bodyFont: t.bodyFont }}>
  .cs { min-height: 100vh; display: grid; place-items: center; background: var(--bg); color: var(--ink); font-family: var(--bodyFont); padding: 24px; }
  .cs-card { max-width: 520px; text-align: center; }
  .cs-brand { font-weight: 900; letter-spacing: 2px; text-transform: uppercase; font-size: 14px; color: var(--accent); }
  h1 { font-family: var(--headingFont); font-size: clamp(28px, 5vw, 44px); line-height: 1.15; }
  .cs-form { display: flex; gap: 10px; margin-top: 28px; }
  .cs-form input { flex: 1; min-width: 0; padding: 13px; border: 1px solid #ccc; border-radius: 10px; font: inherit; }
  .cs-form button { padding: 13px 20px; border: 0; border-radius: 10px; background: var(--accent); color: #fff; font-weight: 800; cursor: pointer; }
  .cs-micro { font-size: 12px; opacity: .7; margin-top: 10px; }
  .sr { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }
  @media (max-width: 520px) { .cs-form { flex-direction: column; } }
</style>
